# Port the API listens on
PORT=4000

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/amplify

# Secret used to sign JWTs — set a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Public base URL of THIS backend. Used to build affiliate share links
# (e.g. https://amplify-api.onrender.com -> share links become <BASE_URL>/r/<CODE>)
BASE_URL=http://localhost:4000

# Optional: if set, POST /api/webhooks/conversion requires this value
# in the `x-webhook-secret` header. Leave empty to disable the check (demo mode).
WEBHOOK_SECRET=
